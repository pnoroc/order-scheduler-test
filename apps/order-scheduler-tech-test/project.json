{
  "name": "order-scheduler-tech-test",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/order-scheduler-tech-test/src",
  "tags": ["type:app"],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/order-scheduler-tech-test",
        "browser": "apps/order-scheduler-tech-test/src/main.ts",
        "tsConfig": "apps/order-scheduler-tech-test/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/order-scheduler-tech-test/public"
          },
          {
            "glob": "**/*",
            "input": "apps/order-scheduler-tech-test/src/assets",
            "output": "assets"
          }
        ],
        "styles": ["node_modules/bootstrap/dist/css/bootstrap.css", "apps/order-scheduler-tech-test/src/styles.scss"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "6kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "order-scheduler-tech-test:build:production"
        },
        "development": {
          "buildTarget": "order-scheduler-tech-test:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/order-scheduler-tech-test/jest.config.cts",
        "tsConfig": "apps/order-scheduler-tech-test/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "order-scheduler-tech-test:build",
        "port": 4200,
        "staticFilePath": "dist/apps/order-scheduler-tech-test/browser",
        "spa": true
      }
    }
  }
}
