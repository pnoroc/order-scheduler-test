        "./libs/feature/work-order-schedule/src/index.ts"
      ],
      "@order-scheduler-tech-test/ui-components": [
        "./libs/ui/ui-components/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
